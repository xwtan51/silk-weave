{
  "name": "silk-weave",
  "private": true,
  "version": "1.0.40",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node server.js & vite",
    "server": "node server.js",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "env -u ELECTRON_RUN_AS_NODE electron .",
    "electron:prod": "env -u ELECTRON_RUN_AS_NODE ELECTRON_PROD=1 electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:win": "npm run build && ELECTRON_MIRROR=\"https://npmmirror.com/mirrors/electron/\" electron-builder --win --x64 -c.buildDependenciesFromSource=false",
    "electron:publish:win": "npm run build && ELECTRON_MIRROR=\"https://npmmirror.com/mirrors/electron/\" electron-builder --win --x64 --publish always -c.buildDependenciesFromSource=false",
    "electron:publish:mac": "npm run build && electron-builder --mac --publish always"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "better-sqlite3": "^12.10.1",
    "cors": "^2.8.6",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "html-to-image": "^1.11.13",
    "i18next": "^26.3.1",
    "lucide-react": "^1.17.0",
    "openai": "^6.42.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^39.8.10",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xwtan51/silk-weave"
  },
  "build": {
    "appId": "com.silkweave.app",
    "buildDependenciesFromSource": false,
    "productName": "Silk-Weave",
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "server.js",
      "dist/**/*",
      "src/data/seed.json",
      "src/data/social-graph.json",
      "server-comments.json"
    ],

    "mac": {
      "category": "public.app-category.education",
      "target": [
        "zip",
        "dmg"
      ],
      "icon": "public/favicon.svg"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Silk-Weave-Setup-${version}.${ext}",
      "icon": "public/favicon.svg"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/favicon.svg"
    }
  }
}